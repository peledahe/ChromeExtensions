{
  "manifest_version": 3,
  "name": "Mk ScreenShot",
  "version": "1.0",
  "description": "Captura y anota la pantalla de manera fácil y rápida (multiplataforma).",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content_detect.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Tomar captura de pantalla"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "screenshot@merke.net",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "key": ""
}