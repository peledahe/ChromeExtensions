{
  "manifest_version": 3,
  "name": "Mk ScreenShot",
  "short_name": "mk-screenshot",
  "version": "1.2",
  "description": "Captura y anota la pantalla de manera fácil y rápida (multiplataforma).",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Tomar captura de pantalla"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "externally_connectable": {
    "ids": ["*"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "screenshot@merke.net",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}