{
  "manifest_version": 3,
  "name": "Mk Agenda & Notas",
  "version": "1.0",
  "description": "Extensión de Agenda, Compras, Ingresos, Kanban, Notas y Claves basada en Minichrome y persistida localmente.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "Abrir Agenda y Notas",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "agenda-notas@merke.net",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "key": ""
}