{
  "manifest_version": 3,
  "name": "Mk Arcade",
  "short_name": "mk-arcade",
  "version": "1.2",
  "description": "Extensión que abre una pestaña de juegos arcade retro (Space Invaders, Asteroids, Trench Run).",
  "permissions": [
    "storage",
    "tabs",
    "webNavigation"
  ],
  "action": {
    "default_title": "Abrir Mk Arcade",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
